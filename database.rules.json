{
  "rules": {
    "players": {
      ".indexOn": ["trophies", "teacherId", "role"],
      "$uid": {
        // Simple owner-based read/write
        ".read": "auth != null && (auth.uid === $uid || root.child('players/' + auth.uid + '/role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('players/' + auth.uid + '/role').val() === 'admin')",
        
        "trophies": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "nickname": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20"
        },
        "role": {
          ".validate": "newData.isString() && (newData.val() === 'admin' || newData.val() === 'teacher' || newData.val() === 'student' || newData.val() === 'player' || newData.val() === 'pending-teacher')"
        },
        "teacherId": {
          ".validate": "(newData.isString() && newData.val().length <= 50) || newData.val() === null"
        },
        "schoolName": {
          ".validate": "(newData.isString() && newData.val().length <= 100) || newData.val() === null"
        },
        "level": {
          ".validate": "newData.isNumber() && newData.val() >= 1"
        },
        "selectedSkinId": {
          ".validate": "newData.isNumber() && newData.val() >= 1"
        },
        "premiumUntil": {
          ".validate": "newData.isNumber()"
        },
        "matchTracking": {
          "lastMatchDate": {
            ".validate": "newData.isString() && newData.val().matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') "
          },
          "matchesToday": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 5"
          }
        }
      }
    },
    "notifications": {
      "$uid": {
         ".read": "auth != null && (auth.uid === $uid || root.child('players/' + auth.uid + '/role').val() === 'admin')",
         ".write": "auth != null && (auth.uid === $uid || root.child('players/' + auth.uid + '/role').val() === 'admin')"
      }
    },
    "rooms": {
      ".indexOn": ["status"],
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",

        "status": {
          ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'playing')"
        },
        "createdAt": {
          ".validate": "newData.isNumber() || !newData.exists()"
        },
        "hostId": {
          ".validate": "newData.isString()"
        },

        "players": {
          "$uid": {
            ".read": "auth != null",
            ".write": "auth.uid === $uid || root.child('rooms/' + $roomId + '/hostId').val() === auth.uid",

            "nickname": {
              ".validate": "newData.isString() && newData.val().length < 20"
            },
            "lives": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "ammo": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "angle": {
              ".validate": "newData.isNumber()"
            },
            "pos": {
              ".validate": "newData.hasChildren(['x','y'])",
              "x": { ".validate": "newData.isNumber()" },
              "y": { ".validate": "newData.isNumber()" }
            },
            "vel": {
              ".validate": "newData.hasChildren(['x','y'])",
              "x": { ".validate": "newData.isNumber()" },
              "y": { ".validate": "newData.isNumber()" }
            },
            "powerUps": {
              ".validate": "newData.hasChildren()",
              "shield": { ".validate": "newData.isNumber()" },
              "rapid": { ".validate": "newData.isNumber()" },
              "speed": { ".validate": "newData.isNumber()" },
              "triple": { ".validate": "newData.isNumber()" }
            }
          }
        },

        "projectiles": {
          ".read": "auth != null",
          "$projId": {
            ".write": "auth != null && !data.exists()",
            ".validate": "newData.hasChildren(['pos', 'vel', 'ownerId', 'timestamp'])",
            "ownerId": { ".validate": "newData.isString() && newData.val() === auth.uid" },
            "timestamp": { ".validate": "newData.isNumber() && newData.val() >= now - 300000 && newData.val() <= now + 300000" },
            "pos": {
              ".validate": "newData.hasChildren(['x','y'])",
              "x": { ".validate": "newData.isNumber()" },
              "y": { ".validate": "newData.isNumber()" }
            },
            "vel": {
              ".validate": "newData.hasChildren(['x','y'])",
              "x": { ".validate": "newData.isNumber()" },
              "y": { ".validate": "newData.isNumber()" }
            }
          }
        },

        "stars": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$starId": {
            ".validate": "newData.hasChildren(['x', 'y', 'active'])",
            "x": { ".validate": "newData.isNumber()" },
            "y": { ".validate": "newData.isNumber()" },
            "active": { ".validate": "newData.isBoolean()" }
          }
        },

        "bots": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('rooms/' + $roomId + '/hostId').val() === auth.uid",
          "$botId": {
            ".validate": "newData.hasChildren(['pos', 'type', 'health'])",
            "type": { ".validate": "newData.isString()" },
            "health": { ".validate": "newData.isNumber()" },
            "maxHealth": { ".validate": "newData.isNumber()" },
            "angle": { ".validate": "newData.isNumber()" },
            "pos": {
              ".validate": "newData.hasChildren(['x','y'])",
              "x": { ".validate": "newData.isNumber()" },
              "y": { ".validate": "newData.isNumber()" }
            }
          }
        }
      }
    },
    "activationCodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && data.exists() && data.child('used').val() == false && newData.child('used').val() === true && newData.child('usedBy').val() === auth.uid",
        ".validate": "newData.hasChildren(['code', 'used', 'usedBy', 'activatedAt'])",
        "code": { ".validate": "newData.isString()" },
        "used": { ".validate": "newData.isBoolean()" },
        "usedBy": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "activatedAt": { ".validate": "newData.isNumber() && (newData.val() >= now - 5000 && newData.val() <= now + 5000)" }
      }
    },
    "premiumUsers": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "premiumExpiresAt": { 
          ".validate": "newData.isNumber() && ( ( data.exists() == false && newData.val() >= now + 2592000000 - 30000 && newData.val() <= now + 2592000000 + 30000 ) || ( data.exists() == true && newData.val() >= (data.val() > now ? data.val() : now) + 2592000000 - 30000 && newData.val() <= (data.val() > now ? data.val() : now) + 2592000000 + 30000 ) )" 
        },
        "lastCode": {
          ".validate": "newData.isString() && newData.val() !== data.val() && root.child('activationCodes/' + newData.val()).child('usedBy').val() === auth.uid"
        }
      }
    },
    "invitations": {
      ".indexOn": ["email", "teacherId", "role"],
      // Allow listing if filtering by email, or if admin/teacher
      ".read": "auth != null && (root.child('players/' + auth.uid + '/role').val() === 'admin' || auth.token.email === 'natanmarinhocanalyt@gmail.com' || (query.orderByChild === 'email' && query.equalTo != null) || (query.orderByChild === 'teacherId' && query.equalTo != null))",
      "$email": {
        ".read": "auth != null && ( (data.exists() && data.child('email').val() === auth.token.email) || root.child('players/' + auth.uid + '/role').val() === 'admin' || (data.exists() && data.child('teacherId').val() === auth.uid) )",
        ".write": "auth != null && (root.child('players/' + auth.uid + '/role').val() === 'admin' || (root.child('players/' + auth.uid + '/role').val() === 'teacher' && newData.child('role').val() === 'student' && newData.child('teacherId').val() === auth.uid && newData.child('email').val().length <= 100 && (!newData.child('schoolName').exists() || newData.child('schoolName').val().length <= 100)))"
      }
    }
  }
}
